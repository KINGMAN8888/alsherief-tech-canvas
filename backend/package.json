{
    "name": "backend",
    "version": "1.0.0",
    "description": "Backend API for Al Sherief Tech Canvas",
    "main": "dist/server.js",
    "scripts": {
        "dev": "npx prisma generate && npx prisma db push --accept-data-loss && ts-node-dev --respawn --transpile-only src/server.ts",
        "build": "tsc",
        "start": "node dist/server.js",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "prisma:generate": "prisma generate",
        "prisma:migrate": "prisma migrate dev",
        "seed:services": "npx tsx src/seed-services.ts",
        "seed:about": "npx tsx src/seed-about.ts"
    },
    "prisma": {
        "seed": "npx tsx prisma/seed.ts",
        "seed:profile": "ts-node src/seed-profile.ts",
        "seed:about": "ts-node src/seed-about.ts"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "dependencies": {
        "@prisma/client": "^6.4.0",
        "@types/compression": "^1.8.1",
        "@types/multer": "^2.0.0",
        "bcryptjs": "^2.4.3",
        "compression": "^1.8.1",
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "express": "^4.19.2",
        "express-rate-limit": "^8.2.1",
        "helmet": "^8.1.0",
        "jsonwebtoken": "^9.0.2",
        "multer": "^2.1.0",
        "node-cache": "^5.1.2",
        "pg": "^8.11.5",
        "winston": "^3.19.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/express-rate-limit": "^5.1.3",
        "@types/helmet": "^0.0.48",
        "@types/jsonwebtoken": "^9.0.6",
        "@types/node": "^20.12.7",
        "@types/supertest": "^7.2.0",
        "@vitest/coverage-v8": "^4.0.18",
        "prisma": "^6.19.2",
        "supertest": "^7.2.2",
        "ts-node-dev": "^2.0.0",
        "tsx": "^4.7.2",
        "typescript": "^5.4.5",
        "vitest": "^4.0.18"
    }
}
